# Brand color palette (nla, blue, green, red, amber, purple, etc.)
NEXT_PUBLIC_BRAND_COLOR=nla

# API Key for protected endpoints (POST, PUT, DELETE)
API_KEY=dev-key-change-in-production

# Base URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# WhatsApp number for orders (NEXT_PUBLIC_ so it works in client components)
NEXT_PUBLIC_WHATSAPP_NUMBER=1234567890

# SEO
NEXT_PUBLIC_INDEXING=false