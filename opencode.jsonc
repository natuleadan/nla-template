{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
  },
  "lsp": {
    "sql": {
      "command": [
        "sql-language-server",
        "up",
        "--method",
        "stdio"
      ],
      "extensions": [
        ".sql"
      ]
    },
      "typescript": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ]
    }
  }
}